# ============================================================
# grandma.app — Environment Variables
# ============================================================
# Copy this file as .env and fill in your real values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git. It is already in .gitignore.
# ============================================================

# ---- Supabase ----
# Where: supabase.com > Your Project > Project Settings > API
# Project URL: the https://xxxx.supabase.co URL shown at the top
# Anon Key: the "anon public" key (safe to expose in client code)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ---- Anthropic (Claude API) ----
# Where: console.anthropic.com > API Keys > Create Key
# This powers Grandma's AI brain via Supabase Edge Functions.
# ALSO store this as a Supabase secret for production:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-xxxx
ANTHROPIC_API_KEY=

# ---- RevenueCat ----
# Where: app.revenuecat.com > Apps & providers > API Keys > SDK API keys
# Use the PUBLIC key (starts with appl_, goog_, or test_).
# The Secret key is only for the server-side webhook — not here.
EXPO_PUBLIC_REVENUECAT_API_KEY=
