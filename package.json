{
  "name": "grandma-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:clear": "expo start --dev-client --clear",
    "start:tunnel": "expo start --dev-client --tunnel",
    "android": "expo start --dev-client --android",
    "ios": "expo start --dev-client --ios",
    "web": "expo start --web",
    "eas:build:dev:ios": "eas build --profile development --platform ios",
    "eas:build:dev:android": "eas build --profile development --platform android",
    "eas:build:sim": "eas build --profile development-simulator --platform ios",
    "eas:build:preview:ios": "eas build --profile preview --platform ios",
    "eas:build:preview:android": "eas build --profile preview --platform android",
    "eas:build:prod:ios": "eas build --profile production --platform ios --auto-submit",
    "eas:build:prod:android": "eas build --profile production --platform android --auto-submit",
    "eas:list": "eas build:list --limit 10",
    "eas:list:ios": "eas build:list --platform ios --limit 10",
    "eas:list:android": "eas build:list --platform android --limit 10",
    "eas:latest": "eas build:view",
    "eas:logs": "eas build:view --logs",
    "eas:cancel": "eas build:cancel",
    "eas:install:sim": "eas build:run --profile development-simulator --platform ios --latest",
    "eas:install:ios": "eas build:run --profile development --platform ios --latest",
    "eas:install:android": "eas build:run --profile development --platform android --latest",
    "eas:submit:ios": "eas submit --platform ios --latest",
    "eas:submit:android": "eas submit --platform android --latest",
    "eas:whoami": "eas whoami",
    "eas:doctor": "npx expo-doctor",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "i18n:check": "npx tsx scripts/i18n-check.ts",
    "i18n:push": "tsx scripts/i18n-export-en.ts && tolgee push --api-key $TOLGEE_API_KEY",
    "i18n:pull": "tolgee pull --api-key $TOLGEE_API_KEY && tsx scripts/i18n-import.ts && npm run i18n:check",
    "i18n:sync": "npm run i18n:push && npm run i18n:pull",
    "lint": "eslint .",
    "lint:i18n": "eslint --rule '{\"i18next/no-literal-string\":\"error\"}' ."
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|nativewind|@supabase/.*|@tanstack/.*|zustand|lucide-react-native))"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.expo/",
      "/dist/",
      "/.claude/worktrees/"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/.claude/worktrees/",
      "<rootDir>/.expo/",
      "<rootDir>/dist/"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  },
  "dependencies": {
    "@expo-google-fonts/abril-fatface": "^0.4.1",
    "@expo-google-fonts/archivo-black": "^0.4.1",
    "@expo-google-fonts/bebas-neue": "^0.4.1",
    "@expo-google-fonts/caveat": "^0.4.2",
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/hanken-grotesk": "^0.4.3",
    "@expo-google-fonts/ibm-plex-serif": "^0.4.1",
    "@expo-google-fonts/instrument-serif": "^0.4.1",
    "@expo-google-fonts/libre-caslon-text": "^0.4.0",
    "@expo-google-fonts/monoton": "^0.4.1",
    "@expo-google-fonts/permanent-marker": "^0.4.0",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo-google-fonts/shrikhand": "^0.4.1",
    "@expo-google-fonts/space-mono": "^0.4.2",
    "@expo-google-fonts/unica-one": "^0.4.2",
    "@expo-google-fonts/yeseva-one": "^0.4.1",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-query": "^5.95.2",
    "babel-preset-expo": "~54.0.10",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.34",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sensors": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-purchases": "^9.15.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@types/react-native": "^0.72.8",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "eslint-plugin-i18next": "^6.1.4",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2"
  },
  "private": true
}
