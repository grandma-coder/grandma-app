{
  "expo": {
    "name": "grandma-app",
    "slug": "grandma-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "grandma-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.grandmacoder.grandmaapp",
      "buildNumber": "3",
      "icon": "./assets/icon.png",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "Save your daily affirmation as an image to share anywhere.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F3ECD9"
      },
      "package": "com.grandmacoder.grandmaapp",
      "versionCode": 3
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#E58BB4"
        }
      ],
      "@sentry/react-native",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "grandmaapp"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3e90f69b-67ad-4c0e-82b5-12677de0e331"
      }
    },
    "owner": "grandma.app"
  }
}
